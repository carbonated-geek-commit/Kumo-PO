---
layout: layouts/base.njk
---

<section class="hero">
  <span class="hero__kanji" aria-hidden="true">{{ site.kanji }}</span>
  <div class="hero__inner hero__inner--split">
    <div class="hero__text">
      <p class="hero__eyebrow">Port Orchard, Washington · Ramen · Sushi · Bowls</p>
      <h1 class="hero__title">Broth worth<br>every drop.</h1>
      <p class="hero__lede">
        A tiny, two-person kitchen making everything from scratch — tonkotsu
        simmered from early morning, chashu that melts in your mouth, and sushi
        rice seasoned fresh three times a day. Port Orchard finally has its
        ramen shop.
      </p>
      <div class="hero__actions">
        {%- if site.ordering.doordashEnabled %}
        <a class="btn btn--ember btn--lg" href="{{ site.ordering.doordashUrl }}" target="_blank" rel="noopener" data-analytics="order_doordash" data-location="hero">Order Now</a>
        {%- else %}
        <a class="btn btn--ember btn--lg" href="tel:{{ site.phone.tel }}" data-analytics="call_order" data-location="hero">Order Now · {{ site.phone.display }}</a>
        {%- endif %}
        <a class="btn btn--ghost btn--lg" href="{{ '/menu/' | url }}" data-analytics="browse_menu" data-location="hero">Take a look around →</a>
      </div>
      <p class="hero__meta">
        <span class="rating" aria-label="Rated {{ site.rating.value }} out of 5 stars">★ {{ site.rating.value }}</span>
        from local diners · {{ site.services | join(' · ') }}
      </p>
    </div>
    <div class="hero__photo">
      <img src="{{ '/assets/photos/tonkotsu-ramen.jpg' | url }}" alt="Tonkotsu ramen at Kumo — creamy pork-bone broth with seared chashu, sweet corn, and bok choy" width="1600" height="1200" fetchpriority="high">
    </div>
  </div>
</section>

<section class="signatures" aria-labelledby="signatures-title">
  <div class="section__inner">
    <h2 class="section__title" id="signatures-title"><span class="section__kanji" aria-hidden="true">名物</span> House signatures</h2>
    <p class="section__lede">Where regulars tell you to start.</p>
    <ul class="signature-grid">
      {%- for section in menu.sections %}{%- for item in section.items %}{%- if item.featured %}
      <li class="signature-card">
        {%- if item.image %}
        <div class="signature-card__art">
          <img src="{{ item.image | url }}" alt="{{ item.name }} at {{ site.name }}" loading="lazy">
        </div>
        {%- elif item.illustration %}
        <div class="signature-card__art signature-card__art--illustration">
          <img src="{{ item.illustration | url }}" alt="Illustration of {{ item.name | lower }}" loading="lazy">
        </div>
        {%- endif %}
        <div class="signature-card__body">
          <h3 class="signature-card__name">{{ item.name }}{% if item.spicy %} <span class="spicy" title="Spicy">辛</span>{% endif %}{% if item.raw %} <span class="raw" title="Served raw or undercooked">生</span>{% endif %}</h3>
          <p class="signature-card__desc">{{ item.description }}</p>
          <div class="signature-card__row">
            <p class="signature-card__price">{% if item.price %}{{ item.price | money }}{% else %}{{ item.priceNote }}{% endif %}</p>
            {%- if item.price %}
            <button class="menu-item__add" type="button"
                    data-add-to-tray
                    data-item-id="{{ item.id }}"
                    data-item-name="{{ item.name }}"
                    data-item-price="{{ item.price }}"
                    data-analytics="tray_add" data-item="{{ item.id }}" data-location="home"
                    aria-label="Add {{ item.name }} to your tray">+ Tray</button>
            {%- endif %}
          </div>
        </div>
      </li>
      {%- endif %}{%- endfor %}{%- endfor %}
    </ul>
    <p class="section__cta">
      <a class="btn btn--ghost" href="{{ '/menu/' | url }}">See the full menu →</a>
    </p>
    <p class="photo-credit">Dish photos by Kumo guests on Google Maps; ink illustrations stand in where a real photo doesn't exist yet.</p>
  </div>
</section>

<section class="story">
  <div class="story__inner">
    <div class="story__panel story__panel--split">
      <span class="section-kanji section-kanji--right section-kanji--on-dark" aria-hidden="true">炭火</span>
      <div class="story__text">
        <h2 class="story__title">A two-person kitchen, all scratch</h2>
        <p>
          Kumo is run by a couple who start before sunrise and close past
          midnight — broth and chashu made in-house, never from a packet, and
          sushi rice seasoned fresh three times a day with their own vinegar
          blend. Five tables, a hand-painted mural, and food that's already
          earned a line out the door.
        </p>
        <p class="story__note">
          It's a small crew in a small room — peak nights can mean a short
          wait. Call ahead for takeout and skip it.
        </p>
        <p><a class="btn btn--ember" href="tel:{{ site.phone.tel }}" data-analytics="call_takeout" data-location="story">Call ahead · {{ site.phone.display }}</a></p>
      </div>
      <div class="story__photo">
        <img src="{{ '/assets/photos/mural.jpg' | url }}" alt="Kumo's hand-painted dining room mural — a samurai lifting noodles from a giant ramen bowl beneath Mt. Fuji" loading="lazy">
      </div>
    </div>
  </div>
</section>

<section class="reviews" id="reviews" aria-labelledby="reviews-title">
  <span class="section-kanji section-kanji--left" aria-hidden="true">声</span>
  <div class="section__inner">
    <h2 class="section__title" id="reviews-title"><span class="section__kanji" aria-hidden="true">声</span> {{ reviews.heading }}</h2>
    <p class="section__lede">{{ reviews.subheading }}</p>

    {%- for review in reviews.items %}{%- if review.featured %}
    <figure class="review-feature">
      <blockquote>“{{ review.quote }}”</blockquote>
      <figcaption><cite>{{ review.author }} · <a href="{{ review.sourceUrl }}" target="_blank" rel="noopener">{{ review.source }}</a>{% if review.date %} · {{ review.date }}{% endif %}</cite></figcaption>
    </figure>
    {%- endif %}{%- endfor %}

    <ul class="review-grid">
      {%- for review in reviews.items %}{%- if not review.featured %}
      <li class="review-card">
        <figure class="review-card__figure">
          <blockquote class="review-card__quote">“{{ review.quote }}”</blockquote>
          <figcaption class="review-card__meta">
            <cite class="review-card__author">{{ review.author }}</cite> ·
            {%- if review.dish %} <span class="review-card__dish">{{ review.dish }}</span> ·{% endif %}
            <a href="{{ review.sourceUrl }}" target="_blank" rel="noopener">{{ review.source }}</a>{% if review.date %} · {{ review.date }}{% endif %}
          </figcaption>
        </figure>
      </li>
      {%- endif %}{%- endfor %}

      <li class="review-card review-card--feed" data-social-feed-slot>
        <button class="review-card__feed-btn" type="button" data-social-feed-load data-analytics="social_feed_load">
          <span class="review-card__feed-kanji" aria-hidden="true">続</span>
          <span>See more from the neighborhood</span>
          <span class="review-card__feed-hint">Loads recent posts</span>
        </button>
      </li>
    </ul>
  </div>
</section>

<section class="visit" id="visit" aria-labelledby="visit-title">
  <span class="section-kanji section-kanji--right" aria-hidden="true">道</span>
  <div class="section__inner visit__grid">
    <div class="visit__info">
      <h2 class="section__title" id="visit-title"><span class="section__kanji" aria-hidden="true">道</span> Come find us</h2>
      <address class="visit__address">
        <strong>{{ site.name }}</strong><br>
        {{ site.address.street }}<br>
        {{ site.address.city }}, {{ site.address.state }} {{ site.address.zip }}
      </address>
      <p class="visit__phone"><a href="tel:{{ site.phone.tel }}" data-analytics="call" data-location="visit">{{ site.phone.display }}</a></p>
      <div class="visit__actions">
        <a class="btn btn--ghost" href="{{ site.address.mapsUrl }}" target="_blank" rel="noopener" data-analytics="map_open" data-location="visit">Directions →</a>
        {%- if site.ordering.doordashEnabled %}
        <a class="btn btn--ember" href="{{ site.ordering.doordashUrl }}" target="_blank" rel="noopener" data-analytics="order_doordash" data-location="visit">Order Delivery</a>
        {%- else %}
        <a class="btn btn--ember" href="tel:{{ site.phone.tel }}" data-analytics="call_order" data-location="visit">Call to Order</a>
        {%- endif %}
      </div>
      <ul class="visit__services">
        {%- for service in site.services %}
        <li class="chip">{{ service }}</li>
        {%- endfor %}
      </ul>
      <div class="visit__photo">
        <img src="{{ '/assets/photos/storefront.jpg' | url }}" alt="Kumo Sushi & Ramen storefront on Village Lane — look for the red noodle-bowl logo in the windows" loading="lazy">
      </div>
    </div>
    <div class="visit__hours">
      <h3 class="visit__hours-title">Hours</h3>
      {% include "partials/hours.njk" %}
    </div>
  </div>
</section>
