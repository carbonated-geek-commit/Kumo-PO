---
layout: layouts/base.njk
title: Menu
permalink: /menu/
pageDescription: "Full menu for Kumo Sushi & Ramen in Port Orchard, WA — scratch-made ramen, rice bowls, karaage, tempura, nigiri, and flame-seared sushi rolls."
---

{% macro menuItem(item, likeCount) %}
<li class="menu-item">
  {%- if item.image %}
  <img class="menu-item__thumb" src="{{ item.image | url }}" alt="" loading="lazy" width="64" height="64">
  {%- endif %}
  <div class="menu-item__text">
    <div class="menu-item__titlerow">
      <h3 class="menu-item__name">
        {{ item.name }}{% if item.spicy %} <span class="spicy" title="Spicy">辛</span>{% endif %}{% if item.raw %} <span class="raw" title="Served raw or undercooked">生</span>{% endif %}
      </h3>
      <button class="like-chip" type="button"
              data-like data-item-id="{{ item.id }}" data-item-name="{{ item.name }}"
              aria-pressed="false" aria-label="Thumbs up {{ item.name }}">
        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg><span class="like-chip__count" data-like-count>{{ likeCount if likeCount else '' }}</span>
      </button>
    </div>
    {%- if item.description %}<p class="menu-item__desc">{{ item.description }}</p>{%- endif %}
    {%- set pub = (item.fanQuotes or []) | selectattr("published") | first %}
    {%- if pub %}<p class="menu-item__quote">“{{ pub.text }}”{% if pub.author %} — {{ pub.author }}{% endif %}</p>{%- endif %}
  </div>
  <div class="menu-item__side">
    <span class="menu-item__price">{% if item.price %}{{ item.price | money }}{% else %}{{ item.priceNote }}{% endif %}</span>
    {%- if item.price %}
    <button class="menu-item__add" type="button"
            data-add-to-tray
            data-item-id="{{ item.id }}"
            data-item-name="{{ item.name }}"
            data-item-price="{{ item.price }}"
            data-analytics="tray_add" data-item="{{ item.id }}"
            aria-label="Add {{ item.name }} to your tray">+ Tray</button>
    {%- endif %}
  </div>
</li>
{% endmacro %}

<section class="menu-hero">
  <div class="section__inner">
    <h1 class="menu-hero__title"><span class="section__kanji" aria-hidden="true">献立</span> The Menu</h1>
    <p class="menu-hero__lede">
      Build your tray as you browse — add whatever looks good, then share it
      with friends or call it in for takeout.
    </p>
    <p class="menu-legend">
      <span class="spicy" title="Spicy">辛</span> spicy ·
      <span class="raw" title="Served raw or undercooked">生</span> raw ·
      <span aria-hidden="true">👍</span> local thumbs-up
    </p>
  </div>
</section>

<div class="menu-stack">
  <nav class="menu-nav" aria-label="Menu sections">
    <div class="menu-nav__inner">
      <ul class="menu-nav__list">
        {%- if favorites.length %}
        <li><a class="menu-nav__link menu-nav__link--fav" href="#favorites">★ Favorites</a></li>
        {%- endif %}
        {%- for section in menu.sections %}
        <li><a class="menu-nav__link" href="#{{ section.id }}">{{ section.title }}</a></li>
        {%- endfor %}
      </ul>
      {# Mobile: Favorites home chip + where-you-are + where-you're-headed (scrollspy-driven) #}
      <div class="menu-nav__compact">
        {%- if favorites.length %}
        <a class="menu-nav__link menu-nav__link--fav" href="#favorites">★ Favorites</a>
        <a class="menu-nav__link menu-nav__link--current is-active" data-spy-current href="#favorites">★ Favorites</a>
        {%- else %}
        <a class="menu-nav__link menu-nav__link--current is-active" data-spy-current href="#{{ menu.sections[0].id }}">{{ menu.sections[0].title }}</a>
        {%- endif %}
        <a class="menu-nav__link menu-nav__link--next" data-spy-next href="#{{ menu.sections[0].id }}">{{ menu.sections[0].title }} →</a>
      </div>
    </div>
  </nav>
  <aside class="menu-tray-bar" aria-label="Your tray summary">
    <span class="menu-tray-bar__label">Your Tray <span class="tray-count" data-tray-count hidden>0</span></span>
    <span class="menu-tray-bar__hint" data-tray-bar-empty>Tap “+ Tray” on any dish to start.</span>
    <span class="menu-tray-bar__hint" data-tray-bar-full hidden>Estimated <strong data-tray-bar-total>$0.00</strong></span>
    <button class="btn btn--ember btn--sm tray-open menu-tray-bar__open" type="button" data-analytics="tray_open" data-location="menu-bar">View</button>
  </aside>
</div>

<div class="menu-body section__inner">
  {%- if favorites.length %}
  <section class="menu-section menu-section--favorites" id="favorites" aria-labelledby="favorites-title">
    <h2 class="menu-section__title" id="favorites-title">Neighborhood Favorites</h2>
    <p class="menu-section__note">The dishes Port Orchard adds to its tray the most.</p>
    <ul class="menu-list">
      {%- for item in favorites %}
      {{ menuItem(item, item.count) }}
      {%- endfor %}
    </ul>
  </section>
  {%- endif %}

  {%- for section in menu.sections %}
  <section class="menu-section" id="{{ section.id }}" aria-labelledby="{{ section.id }}-title">
    <h2 class="menu-section__title" id="{{ section.id }}-title">{{ section.title }}</h2>
    {%- if section.note %}<p class="menu-section__note">{{ section.note }}</p>{%- endif %}
    <ul class="menu-list">
      {%- for item in section.items %}
      {{ menuItem(item, (popularity.counts[item.id] or 0) + (item.likesAdjust or 0)) }}
      {%- endfor %}
    </ul>
  </section>
  {%- endfor %}

  <p class="menu-disclaimer">{{ menu.disclaimer }}</p>
</div>
